rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 사용자 프로필 + 모든 도메인 데이터 ───────────────
    match /users/{uid}/{collection=**} {
      // 본인만 read/write
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── 공유 링크 ─────────────────────────────────────
    match /shares/{shareId} {
      // 누구나 읽기 (보기 전용 공유)
      allow read: if true;

      // 쓰기는 소유자만 (생성·삭제·수정)
      allow create: if request.auth != null
                  && request.resource.data.ownerUid == request.auth.uid;

      allow update, delete: if request.auth != null
                          && resource.data.ownerUid == request.auth.uid;
    }

    // ── 그룹 (Phase 5: 공동 플랜) ──────────────────
    match /groups/{groupId} {
      // 멤버만 read
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberUids;

      // 만들기: 본인이 owner 이고 memberUids 에 본인만 있어야 함
      allow create: if request.auth != null
                  && request.resource.data.ownerUid == request.auth.uid
                  && request.resource.data.memberUids == [request.auth.uid]
                  && request.resource.data.memberUids.size() <= 10;

      // 업데이트:
      //   1) 기존 멤버: 자유로운 변경 (단, ownerUid 불변 + 10명 한도)
      //   2) 비멤버의 가입: memberUids 에 본인만 추가, 기존 멤버 보존, 10명 한도
      allow update: if request.auth != null
                  && request.resource.data.ownerUid == resource.data.ownerUid
                  && request.resource.data.memberUids.size() <= 10
                  && (
                    request.auth.uid in resource.data.memberUids
                    || (
                      request.auth.uid in request.resource.data.memberUids
                      && request.resource.data.memberUids.hasAll(resource.data.memberUids)
                    )
                  );

      // 삭제: owner 만
      allow delete: if request.auth != null
                  && request.auth.uid == resource.data.ownerUid;

      // 그룹 일정 — 그룹 멤버만 read/write
      match /events/{eventId} {
        allow read, write: if request.auth != null
                          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
      }

      // 그룹 할일 — 그룹 멤버만 read/write
      match /todos/{todoId} {
        allow read, write: if request.auth != null
                          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
      }
    }

    // ── 초대 코드 인덱스 ─────────────────────────────
    match /invites/{inviteCode} {
      // 인증 사용자는 누구나 코드로 조회 가능 (가입 흐름)
      allow read: if request.auth != null;

      // 만들기: 본인이 owner 인 그룹의 invite 만
      allow create: if request.auth != null
                  && request.resource.data.ownerUid == request.auth.uid;

      // 업데이트 / 삭제: 본인이 owner 일 때만 (이름 변경 / 그룹 삭제 시)
      allow update, delete: if request.auth != null
                          && resource.data.ownerUid == request.auth.uid;
    }

    // ── 가입 전 이메일 초대 보관 ─────────────────────
    // emailKey 는 클라이언트에서 정규화 — MVP 라 인증 사용자에게 read/write 허용
    match /pendingInvites/{emailKey}/list/{inviteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // 그 외 모든 경로 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
