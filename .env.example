# 이 파일은 템플릿입니다. 복사해서 `.env.local`로 만들고 실제 값을 채우세요.
# .env.local은 .gitignore에 등록되어 있어 절대 커밋되지 않습니다.

# ─── 공공데이터포털 공휴일 API ────────────────────
# data.go.kr → 마이페이지 → 인증키(Decoding) 값을 사용하세요
VITE_HOLIDAY_API_KEY=your_decoded_service_key_here

# ─── OpenAI ─────────────────────────────────────
# 서버에서만 사용 (Edge Functions). 클라이언트 빌드물에 포함되지 않음.
OPENAI_API_KEY=sk-...

# ─── Firebase (Vite는 VITE_ 접두어가 붙은 변수만 클라이언트에 노출) ─
VITE_FIREBASE_API_KEY=AIzaSyD4vxQu2_OAZLUNsO2YqODiy9Obh1KNMVk
VITE_FIREBASE_AUTH_DOMAIN=kdt-webai-team-planner.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=kdt-webai-team-planner
VITE_FIREBASE_STORAGE_BUCKET=kdt-webai-team-planner.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=568047862799
VITE_FIREBASE_APP_ID=1:568047862799:web:06da2561912c5d90090f7a

# ─── Firebase Admin (Edge Functions에서 idToken 검증용) ─
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# PRIVATE_KEY는 절대 커밋하지 마세요. .env.local에만 채워서 사용.
FIREBASE_ADMIN_PROJECT_ID=kdt-webai-team-planner
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-fbsvc@kdt-webai-team-planner.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<paste your key here>\n-----END PRIVATE KEY-----\n"
