# 이 파일은 템플릿입니다. 복사해서 `.env.local`로 만들고 실제 값을 채우세요.
# .env.local은 .gitignore에 등록되어 있어 절대 커밋되지 않습니다.

# ─── OpenAI ─────────────────────────────────────
# 서버에서만 사용 (Edge Functions). 클라이언트 빌드물에 포함되지 않음.
OPENAI_API_KEY=sk-...

# ─── Firebase (Vite는 VITE_ 접두어가 붙은 변수만 클라이언트에 노출) ─
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Firebase Admin (Edge Functions에서 idToken 검증용) ─
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
