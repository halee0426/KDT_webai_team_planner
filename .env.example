# 이 파일은 템플릿입니다. 복사해서 `.env.local`로 만들고 실제 값을 채우세요.
# .env.local은 .gitignore에 등록되어 있어 절대 커밋되지 않습니다.

# ─── 공공데이터포털 공휴일 API ────────────────────
# data.go.kr → 마이페이지 → 인증키(Decoding) 값을 사용하세요
VITE_HOLIDAY_API_KEY=your_decoded_service_key_here

# ─── OpenAI ─────────────────────────────────────
# 서버에서만 사용 (Edge Functions). 클라이언트 빌드물에 포함되지 않음.
OPENAI_API_KEY=sk-...

# ─── Firebase (Vite는 VITE_ 접두어가 붙은 변수만 클라이언트에 노출) ─
VITE_FIREBASE_API_KEY=AIzaSyD4vxQu2_OAZLUNsO2YqODiy9Obh1KNMVk
VITE_FIREBASE_AUTH_DOMAIN=kdt-webai-team-planner.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=kdt-webai-team-planner
